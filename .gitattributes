vagrant/boxes/*.box filter=lfs diff=lfs merge=lfs -text
vagrant/boxes/*.ova filter=lfs diff=lfs merge=lfs -text
vagrant/boxes/*.ovf filter=lfs diff=lfs merge=lfs -text
vagrant/boxes/*.vmdk filter=lfs diff=lfs merge=lfs -text

# Force LF endings for anything exec'd via a shebang (inside Linux containers,
# Vagrant provisioners, or directly). Without this, a Windows checkout with
# core.autocrlf=true silently breaks every one of these with either
# "no such file or directory" (Docker CMD execing a CRLF shebang) or
# "$'\r': command not found" (Vagrant shell provisioning).
*.sh text eol=lf
*.py text eol=lf
Dockerfile* text eol=lf
Makefile text eol=lf

# Vendored upstream C library - leave its own line-ending conventions alone,
# don't let the rules above apply inside it.
open62541/** -text
