# Core stack ports
HISTORIAN_WEB_PORT=5000
GRAFANA_PORT=3000
LOKI_PORT=3100
PROMTAIL_PORT=9080

# Primary historian
HISTORIAN_WEB_SERVICE_NAME=historian_web
HISTORIAN_INGEST_SERVICE_NAME=historian_ingest
HISTORIAN_USERNAME=operator
HISTORIAN_PASSWORD=operator123
SERVER_BASE=http://localhost:5000
OPCUA_URL=opc.tcp://192.168.1.11:4840
OPCUA_NAMESPACE=http://manufacturing.example/opcua
POLL_INTERVAL_SECONDS=1.0

# Optional second historian profile (enabled with --profile multi)
HISTORIAN2_WEB_SERVICE_NAME=historian2_web
HISTORIAN2_INGEST_SERVICE_NAME=historian2_ingest
HISTORIAN2_WEB_PORT=5001
HISTORIAN2_SERVER_BASE=http://localhost:5001
HISTORIAN2_USERNAME=operator2
HISTORIAN2_PASSWORD=operator2
OPCUA_URL_2=opc.tcp://192.168.1.12:4840
OPCUA_NAMESPACE_2=http://manufacturing.example/opcua
POLL_INTERVAL_SECONDS_2=1.0

# Grafana auth
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
