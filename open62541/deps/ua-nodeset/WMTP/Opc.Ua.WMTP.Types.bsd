<opc:TypeDictionary DefaultByteOrder="LittleEndian" xmlns:opc="http://opcfoundation.org/BinarySchema/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ua="http://opcfoundation.org/UA/" xmlns:tns="http://opcfoundation.org/UA/WMTP/" TargetNamespace="http://opcfoundation.org/UA/WMTP/">
    <opc:Import Namespace="http://opcfoundation.org/UA/"/>
    <opc:StructuredType BaseType="ua:ExtensionObject" Name="WMTPOutputDataType">
        <opc:Field Name="EngineeringUnits" TypeName="ua:EUInformation"/>
        <opc:Field Name="ActualValue" TypeName="opc:Double"/>
        <opc:Field Name="TypeOfMeasurement" TypeName="opc:UInt32"/>
        <opc:Field Name="TypeOfSample" TypeName="opc:UInt32"/>
        <opc:Field Name="InstrumentRange" TypeName="ua:Range"/>
        <opc:Field Name="EURange" TypeName="ua:Range"/>
        <opc:Field Name="ValuePrecision" TypeName="opc:Double"/>
        <opc:Field Name="Definition" TypeName="opc:CharArray"/>
        <opc:Field Name="SignalTag" TypeName="opc:CharArray"/>
        <opc:Field Name="RelativeUncertainty" TypeName="opc:Double"/>
        <opc:Field Name="AbsoluteUncertainty" TypeName="opc:Double"/>
        <opc:Field Name="Timestamp" TypeName="opc:DateTime"/>
        <opc:Field Name="Index" TypeName="opc:UInt32"/>
        <opc:Field Name="MeasurementPeriod" TypeName="opc:Double"/>
        <opc:Field Name="InternalUpdateInterval" TypeName="opc:Double"/>
    </opc:StructuredType>
</opc:TypeDictionary>
