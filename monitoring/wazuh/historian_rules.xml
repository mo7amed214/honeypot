<group name="local,historian,application,">

  <rule id="100200" level="3">
    <if_sid>86600</if_sid>
    <field name="service" type="pcre2">^historian_(service|web|ingest)$</field>
    <description>Historian application event observed.</description>
    <group>historian,application,</group>
  </rule>

  <rule id="100201" level="4">
    <if_sid>100200</if_sid>
    <field name="event_type">portal_visit</field>
    <description>Historian portal visited.</description>
    <group>historian,application,</group>
  </rule>

  <rule id="100202" level="4">
    <if_sid>100200</if_sid>
    <field name="event_type">portal_history_query</field>
    <description>Historian history query observed.</description>
    <group>historian,application,</group>
  </rule>

  <rule id="100203" level="3">
    <if_sid>100200</if_sid>
    <field name="event_type">portal_live_poll</field>
    <description>Historian live polling observed.</description>
    <group>historian,application,</group>
  </rule>

  <rule id="100204" level="5">
    <if_sid>100200</if_sid>
    <field name="event_type">ingest_connection</field>
    <description>Historian ingest connection event observed.</description>
    <group>historian,application,</group>
  </rule>

  <rule id="100205" level="6">
    <if_sid>100200</if_sid>
    <field name="event_type">ingest_anomaly</field>
    <description>Historian ingest anomaly observed.</description>
    <group>historian,application,</group>
  </rule>

  <rule id="100206" level="8">
    <if_sid>100204</if_sid>
    <match type="pcre2">"status"\s*:\s*"error"</match>
    <description>Historian ingest connection error detected.</description>
    <group>historian,application,</group>
  </rule>

  <rule id="100207" level="8">
    <if_sid>100200</if_sid>
    <field name="event_type">login_attempt</field>
    <match type="pcre2">"status"\s*:\s*"failed"</match>
    <description>Historian failed login attempt detected.</description>
    <group>historian,application,authentication_failed,</group>
  </rule>

  <rule id="100208" level="7">
    <if_sid>100200</if_sid>
    <field name="event_type">api_probe</field>
    <description>Historian API/admin probe access observed.</description>
    <group>historian,application,web,</group>
  </rule>

  <rule id="100209" level="10">
    <if_sid>100205</if_sid>
    <match type="pcre2">"status"\s*:\s*"high"</match>
    <description>Historian high-severity ingest anomaly detected.</description>
    <group>historian,application,anomaly,</group>
  </rule>

  <rule id="100210" level="7">
    <if_sid>100200</if_sid>
    <field name="event_type">query_history</field>
    <description>Historian unauthenticated tag-history endpoint accessed.</description>
    <group>historian,application,web,</group>
  </rule>

</group>
