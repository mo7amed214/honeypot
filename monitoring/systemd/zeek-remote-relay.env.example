REMOTE_SENSOR_HOST=192.168.1.20
REMOTE_SENSOR_USER=analyst
REMOTE_SENSOR_PORT=22
REMOTE_SOURCE_LOG=/opt/zeek/spool/zeek/conn.log
REMOTE_SOURCE_LOGS="/opt/zeek/spool/zeek/conn.log /opt/zeek/spool/zeek/ssh.log /opt/zeek/spool/zeek/http.log /opt/zeek/spool/zeek/smb_mapping.log /opt/zeek/spool/zeek/smb_files.log /opt/zeek/spool/zeek/opcua_write.log /opt/zeek/spool/zeek/discovery_scan.log"
TARGET_LOG=/home/ceo/zeek_feed.log
REMOTE_USE_SUDO=1

# Prefer SSH keys for the relay service.
# REMOTE_SENSOR_KEY=/root/.ssh/id_ed25519

# Use only if you must rely on password auth and sshpass is installed.
# REMOTE_SENSOR_PASSWORD=change-me
