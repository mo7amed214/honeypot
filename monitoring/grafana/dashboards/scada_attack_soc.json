{
  "title": "SOC — ICS Attack Monitor (Level 2 SCADA)",
  "uid": "scada-soc-l2",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["honeypot", "ics", "soc"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CRITICAL Alarms (last 30 min)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum(count_over_time({job=\"scada_l2_audit\", severity=\"CRITICAL\"}[30m]))",
          "legendFormat": "CRITICAL"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Attack Events (last 30 min)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum(count_over_time({job=\"scada_l2_audit\"}[30m]))",
          "legendFormat": "Events"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Most Recent MITRE Technique",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "last_over_time({job=\"scada_l2_audit\"} | json | __error__=\"\" | mitre_technique != \"\" [30m])",
          "legendFormat": "{{mitre_technique}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Purdue Level Under Attack",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "grafana", "uid": "-- Grafana --" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana", "uid": "-- Grafana --" },
          "queryType": "randomWalk"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {}
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "name",
        "colorMode": "background"
      },
      "overrides": [
        {
          "matcher": { "id": "byName", "options": "Value" },
          "properties": [{ "id": "displayName", "value": "Purdue Level 2 — SCADA / MTU" }]
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "SCADA Attack Event Rate (events / 30s)",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 6 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (severity) (count_over_time({job=\"scada_l2_audit\"}[30s]))",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "logs",
      "title": "Live SCADA Audit Log — Level 2 Attack Events",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "{job=\"scada_l2_audit\"} | json | __error__=\"\"",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 30,
      "type": "bargauge",
      "title": "Events by MITRE Technique (last 30 min)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (mitre_technique) (count_over_time({job=\"scada_l2_audit\"} | json | __error__=\"\" [30m]))",
          "legendFormat": "{{mitre_technique}}"
        }
      ]
    },
    {
      "id": 31,
      "type": "bargauge",
      "title": "Events by Severity (last 30 min)",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["sum"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
          "expr": "sum by (severity) (count_over_time({job=\"scada_l2_audit\"} | json | __error__=\"\" [30m]))",
          "legendFormat": "{{severity}}"
        }
      ]
    }
  ]
}
